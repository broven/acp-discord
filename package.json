{
  "name": "acp-discord",
  "version": "0.1.0",
  "description": "Discord bot that wraps ACP protocol for coding agents",
  "type": "module",
  "bin": {
    "acp-discord": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/broven/acp-discord.git"
  },
  "bugs": {
    "url": "https://github.com/broven/acp-discord/issues"
  },
  "homepage": "https://github.com/broven/acp-discord#readme",
  "license": "MIT",
  "packageManager": "pnpm@10.14.0",
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.15.0",
    "commander": "^14.0.3",
    "discord.js": "^14.25.1",
    "smol-toml": "^1.6.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
